{
  "name": "expo-ios-emoji-picker",
  "version": "0.1.0",
  "description": "Native iOS emoji picker for Expo — opens the system emoji keyboard and resolves with the picked emoji",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "build": "node internal/module_scripts/build.js",
    "clean": "node internal/module_scripts/clean.js",
    "lint": "eslint src/",
    "test": "node internal/module_scripts/test.js",
    "prepare": "node internal/module_scripts/prepare.js",
    "open:ios": "node internal/module_scripts/open-ios.js",
    "open:android": "node internal/module_scripts/open-android.js"
  },
  "keywords": [
    "expo",
    "expo-module",
    "react-native",
    "ios",
    "emoji",
    "emoji-picker",
    "emoji-keyboard",
    "native"
  ],
  "repository": "https://github.com/alfonsobries/expo-ios-emoji-picker",
  "bugs": {
    "url": "https://github.com/alfonsobries/expo-ios-emoji-picker/issues"
  },
  "author": "Alfonso Bribiesca <alfonso@vexilo.com> (https://alfonsobries.com)",
  "license": "MIT",
  "homepage": "https://github.com/alfonsobries/expo-ios-emoji-picker#readme",
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/jest": "^29.2.1",
    "@types/react": "~19.1.1",
    "babel-preset-expo": "~55.0.8",
    "eslint": "~9.39.4",
    "eslint-config-universe": "^15.0.3",
    "expo": "^57.0.2",
    "jest": "^29.7.0",
    "prettier": "^3.0.0",
    "react-native": "0.82.1",
    "semantic-release": "^25.0.5",
    "typescript": "^5.9.2"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ],
    "transform": {
      "^.+\\.(t|j)sx?$": [
        "babel-jest",
        {
          "presets": [
            "babel-preset-expo"
          ]
        }
      ]
    }
  },
  "peerDependencies": {
    "expo": "*",
    "react": "*",
    "react-native": "*"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
